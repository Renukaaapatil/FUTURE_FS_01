<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Renuka Patil - Computer Engineering Student, Web Developer Portfolio">
    <meta name="keywords" content="Renuka Patil, Web Developer, Portfolio, NMIMS">
